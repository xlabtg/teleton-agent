{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/index.ts",
        "src/cli/**/*.ts",
        "src/webui/**/*.ts",
        "src/agent/index.ts",
        "src/telegram/index.ts",
        "src/telegram/callbacks/index.ts",
        "src/sdk/hooks/index.ts",
        "src/constants/index.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignore": ["src/**/__tests__/**", "src/telegram/media-utils.ts"]
    },
    "packages/sdk": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["src/**/__tests__/**"]
    }
  },
  "ignoreDependencies": [
    "pino-pretty",
    "crypto-js",
    "lottie-react",
    "@teleton-agent/sdk",
    "@grammyjs/types",
    "better-sqlite3"
  ],
  "ignoreExportsUsedInFile": true,
  "exclude": ["exports", "types"]
}
